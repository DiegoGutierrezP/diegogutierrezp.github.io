---
import { ProjectItem } from "./ProjectItem";

const projects = [
  {
    title: "Fullfillment system",
    description:
      "Sistema fullfillment para la gestion de inventario y procesamiento de pedidos de marketplace Juntoz",
  },
  {
    title: "Sfibras",
    description:
      "Software ERP para la gestión de todos los procesos de la empresa Sfibras, con módulos de facturación, administración, inventario, ventas, postventa, etc.",
  },
  {
    title: "Roobin",
    description:
      "Asistente virtual que utiliza la API ChatGPT para WhatsApp. Este asistente se integra con diversas aplicaciones de productividad como Gmail, Todoist, Notion, Google Calendar y Slack.",
  },
  {
    title: "Sigma DMS",
    description: "Software de gestión automotriz",
  },
  {
    title: "Plazbot Mail",
    description:
      "Plataforma de correo electrónico para gestionar tickets e incidentes, con creación de buzones compartidos y chat online integrado.",
  },
  {
    title: "Clinic System",
    description:
      "Software de gestión para clínicas, con módulos de citas, historia clínica, facturación, inventario y reportes.",
  },
];
---

<section class="projects-section">
  <h1 class="section-title">Projects</h1>
  <div class="projects-section__content">
    {
      projects.map((p) => (
        // <div class="projects-section__content-item">
        //   <h3>{p.title}</h3>
        //   <p>{p.description}</p>
        // </div>
        <ProjectItem client:load project={p} />
      ))
    }
  </div>
</section>

<style is:global>
  .projects-section__title {
    font-family: var(--font-montserrat);
    font-size: 4.5rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .projects-section__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .projects-section__content-item {
    border-radius: 0.8rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    border: #283142 1px solid;
  }

  .projects-section__content-item:hover {
    background-color: #283142;
  }

  .projects-section__content-item h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-family: var(--font-montserrat);
  }

  .projects-section__content-item p {
    font-size: 1rem;
    color: #bdbdbd;
    font-weight: 500;
    margin: 0;
  }

  @media (max-width: 768px) {
    .projects-section__title {
      font-size: 2.5rem;
    }

    .projects-section__content-item p {
      font-size: 0.9rem;
    }
  }
</style>
