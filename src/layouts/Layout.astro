---
import { Font } from "astro:assets";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import ProfileCard from "../components/ProfileCard.astro";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="keywords"
      content="Diego Gutierrez,Ingeniero de software,Software Engineer, FullStack Developer, Portafolio, Desarrollo Web, React, Astro, Node.js"
    />
    <meta
      name="description"
      content="Portafolio de Diego Gutierrez - Desarrollador Full Stack"
    />
    <meta name="author" content="Diego Gutierrez" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Portafolio | Diego Gutierrez" />
    <meta
      property="og:description"
      content="Soy Diego Gutierrez, Fullstack Developer. Mira mis proyectos y experiencia."
    />
    <meta property="og:url" content="https://diegogutierrezp.github.io/" />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
    <link rel="icon" type="image/png" href="/laptop-icon.png" />
    <link rel="apple-touch-icon" href="/laptop-icon.png" />
    <link rel="canonical" href={Astro.url} />
    <meta name="generator" content={Astro.generator} />
    <title>Diego Gutierrez</title>
    <Font cssVariable="--font-roboto-mono" />
    <Font cssVariable="--font-montserrat" />
    <Font cssVariable="--font-outfit" />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <div class="main-content">
      <div class="container">
        <nav>
          <ProfileCard transition:persist />
        </nav>
        <main>
          <slot />
        </main>
      </div>
    </div>
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
    font-family: var(--font-montserrat);
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-background);
    color: white;
  }

  body {
    font-weight: 400;
    line-height: 1.6;
  }

  .main-content {
    flex: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
    box-sizing: border-box;
  }

  .container {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    min-height: calc(100vh - 120px);
    margin: auto;
  }

  .container nav {
    position: sticky;
    top: 100px;
    height: fit-content;
    max-height: 100vh;
    overflow-y: auto;
  }

  .container main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .container {
      grid-template-columns: 280px 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .main-content {
      padding: 16px;
    }

    .container {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
    }

    .container nav {
      position: static;
      height: auto;
      max-height: none;
      overflow-y: visible;
    }
  }

  @media (max-width: 480px) {
    .main-content {
      padding: 0 12px;
    }

    .container {
      gap: 1.5rem;
    }
  }
</style>
