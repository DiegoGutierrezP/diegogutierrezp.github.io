---
import { Image } from "astro:assets";
import awsCertImg from "../assets/images/certificates/amazon_web_services_logo.jpg";
import efeSetImg from "../assets/images/certificates/efset_logo.jpg";
import hackerRankImg from "../assets/images/certificates/hackerrank_logo.jpg";
import ibmImg from "../assets/images/certificates/ibm_logo.jpg";
import scrumStudyImg from "../assets/images/certificates/1631356592679.jpg";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const certs = [
  {
    url: "https://www.credly.com/badges/63052fe5-a657-4551-a641-90b3ca27ee25/linked_in_profile",
    img: awsCertImg,
    alt: "AWS Cloud Practitioner Certificate",
    name: "AWS Cloud Practitioner Certificate",
    issuer: "Amazon Web Services",
  },
  {
    url: "https://cert.efset.org/es/CUp5T6",
    img: efeSetImg,
    alt: "Certificado EF SET Inglés 70/100 (C1)",
    name: "Certificado EF SET Inglés 70/100 (C1 Avanzado)",
    issuer: "EF SET",
  },
  {
    url: "https://www.hackerrank.com/certificates/iframe/b9609ae10d4e",
    img: hackerRankImg,
    alt: "SQL (Advanced)",
    name: "SQL (Advanced)",
    issuer: "HackerRank",
  },
  {
    url: "https://www.hackerrank.com/certificates/iframe/ef49d1e2d18f",
    img: hackerRankImg,
    alt: "C#",
    name: "C#",
    issuer: "HackerRank",
  },
  {
    url: "https://www.credly.com/badges/bdfd5fa1-198f-4bdc-b4c6-c7826553d010/linked_in_profile",
    img: awsCertImg,
    alt: "AWS Educate Introduction to Generative AI",
    name: "AWS Educate Introduction to Generative AI",
    issuer: "Amazon Web Services",
  },
  {
    url: "https://www.credly.com/badges/321ce5be-ad5a-4696-a012-cc1c5c962eb0/linked_in_profile",
    img: awsCertImg,
    alt: "AWS Educate Getting Started with Serverless",
    name: "AWS Educate Getting Started with Serverless",
    issuer: "Amazon Web Services",
  },
  {
    url: "https://www.credly.com/badges/82ec5496-d79f-4c1a-98ca-e23db5945dc5/public_url",
    img: awsCertImg,
    alt: "AWS Educate Getting Started with Storage",
    name: "AWS Educate Getting Started with Storage",
    issuer: "Amazon Web Services",
  },
  {
    url: "https://www.credly.com/badges/c3d110d5-5886-4959-8514-7aa4cb76244a/public_url",
    img: ibmImg,
    alt: "Python for Data Science",
    name: "Python for Data Science",
    issuer: "IBM",
  },
  {
    url: "https://www.credly.com/badges/da62a894-1718-4cd7-bb26-b16005d6fe63/public_url",
    img: ibmImg,
    alt: "Docker Essentials: A Developer Introduction",
    name: "Docker Essentials: A Developer Introduction",
    issuer: "IBM",
  },
  {
    url: "https://www.linkedin.com/redir/redirect/?url=https%3A%2F%2Fc46e136a583f7e334124-ac22991740ab4ff17e21daf2ed577041.ssl.cf1.rackcdn.com%2FCertificate%2FScrumFundamentalsCertified-DiegoGuti%C3%A9rrezPineda-973694.pdf&urlhash=UIMT&isSdui=true&lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_certifications_details%3BL1KtroPGRvytS4ALHlsSbA%3D%3D",
    img: scrumStudyImg,
    alt: "Scrum Fundamentals",
    name: "Scrum Fundamentals",
    issuer: "Scrum Study",
  },
  {
    url: "https://www.linkedin.com/redir/redirect/?url=https%3A%2F%2Fc46e136a583f7e334124-ac22991740ab4ff17e21daf2ed577041.ssl.cf1.rackcdn.com%2FCertificate%2FScrumFundamentalsCertified-DiegoGuti%C3%A9rrezPineda-973694.pdf&urlhash=UIMT&isSdui=true&lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_certifications_details%3BL1KtroPGRvytS4ALHlsSbA%3D%3D",
    img: scrumStudyImg,
    alt: "Six Sigma Yellow Belt",
    name: "Six Sigma Yellow Belt",
    issuer: "Scrum Study",
  },
  {
    url: "https://www.credly.com/badges/aa678c6e-e908-4fc7-893e-9fa32f04133a/public_url",
    img: awsCertImg,
    alt: "AWS Educate Getting Started with Networking",
    name: "AWS Educate Getting Started with Networking",
    issuer: "Amazon Web Services",
  },
];

const half = Math.ceil(certs.length / 2);
const row1 = certs.slice(0, half);
const row2 = certs.slice(half);
---

<section class="certificates-section">
  <h1 class="section-title">{t("certificates.title")}</h1>
  <div class="carousel-outer">
    <!-- Fila 1 — izquierda -->
    <div class="carousel-row row1">
      {
        [...row1, ...row1].map((c) => (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="cert-card"
          >
            <Image
              src={c.img}
              alt={c.alt}
              width={56}
              height={56}
              class="cert-logo"
            />
            <div>
              <h3 class="cert-name">{c.name}</h3>
              <h5 class="cert-issuer">{c.issuer}</h5>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Fila 2 — derecha -->
    <div class="carousel-row row2">
      {
        [...row2, ...row2].map((c) => (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="cert-card"
          >
            <Image
              src={c.img}
              alt={c.alt}
              width={56}
              height={56}
              class="cert-logo"
            />
            <div>
              <h3 class="cert-name">{c.name}</h3>
              <h5 class="cert-issuer">{c.issuer}</h5>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .certificates-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  /* Fade en los bordes */
  .carousel-outer {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    margin: 2rem 0;
    /* -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    ); */
  }

  .carousel-outer:hover .carousel-row {
    animation-play-state: paused;
  }

  .carousel-row {
    display: flex;
    gap: 1rem;
    width: max-content;
  }

  .row1 {
    animation: scroll-left 35s linear infinite;
  }

  .row2 {
    animation: scroll-right 40s linear infinite;
  }

  @keyframes scroll-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes scroll-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    /* background: #283142; */
    background-color: var(--color-background-secondary);
    border-radius: 0.8rem;
    padding: 0.9rem 1.25rem;
    width: 280px;
    flex-shrink: 0;

    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      border-color 0.4s ease,
      transform 0.3s ease;
  }

  .cert-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.03) 30%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.03) 70%,
      transparent 100%
    );
    transform: skewX(-15deg);
    pointer-events: none;
    transition: none;
  }

  .cert-card:hover {
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
  }

  .cert-card:hover::before {
    animation: shine 0.65s ease forwards;
  }

  @keyframes shine {
    0% {
      left: -100%;
    }
    100% {
      left: 160%;
    }
  }

  .cert-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  .cert-name {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.25rem;
    line-height: 1.3;
    color: #fff;
  }

  .cert-issuer {
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  @media (max-width: 768px) {
    .certificates-section__title {
      font-size: 2.5rem;
    }
  }
</style>
