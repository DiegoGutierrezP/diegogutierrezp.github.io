---
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="footer__container">
    {/* Desktop Layout */}
    <div class="footer__desktop">
      {/* Company Info */}
      <div class="footer__info">
        <h3 class="footer__title">Diego Gutierrez</h3>
        <p class="footer__description">
          {t("footer.description")}
        </p>
      </div>

      {/* Social Links */}
      <div class="footer__social-section">
        <h4 class="footer__subtitle">{t("footer.contactme")}</h4>
        <div class="footer__social-links">
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="GitHub"
          >
            <Icon name="mdi:github" class="footer__icon" />
          </a>
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="LinkedIn"
          >
            <Icon name="mdi:linkedin" class="footer__icon" />
          </a>
          <a
            href="mailto:diego.gup.75@gmail.com"
            class="footer__social-link"
            aria-label="Email"
          >
            <Icon name="mdi:email" class="footer__icon" />
          </a>
        </div>
      </div>
    </div>

    {/* Mobile Layout */}
    <div class="footer__mobile">
      <div class="footer__mobile-social">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__social-link"
        >
          <Icon name="mdi:github" class="footer__icon" />
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__social-link"
        >
          <Icon name="mdi:linkedin" class="footer__icon" />
        </a>
        <a href="mailto:contact@example.com" class="footer__social-link">
          <Icon name="mdi:email" class="footer__icon" />
        </a>
      </div>
    </div>

    {/* Divider */}
    <div class="footer__divider"></div>

    {/* Bottom Section */}
    <div class="footer__bottom">
      <p>
        &copy; {new Date().getFullYear()} Diego Gutierrez. {
          t("footer.copyright")
        }
      </p>
      <p>
        {t("footer.made")}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__link">Astro</a
        >
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1rem;
    padding-top: 4rem;
    padding-bottom: 0;
  }

  /* Desktop Layout */
  .footer__desktop {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer__info {
    grid-column: span 2;
  }

  .footer__title {
    color: white;
    font-weight: bold;
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .footer__description {
    color: #9ca3af;
    font-size: 0.875rem;
    line-height: 1.625;
    max-width: 85%;
  }

  .footer__social-section {
    /* aligned to the right */
  }

  .footer__subtitle {
    color: white;
    font-weight: bold;
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .footer__social-links {
    display: flex;
    gap: 1rem;
  }

  .footer__social-link {
    padding: 0.5rem;
    background-color: var(--color-background-secondary);
    border-radius: 0.5rem;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__social-link:hover {
    background-color: var(--color-primary);
  }

  .footer__icon {
    width: 1.5rem;
    height: 1.5rem;
    color: #9ca3af;
  }

  .footer__social-link:hover .footer__icon {
    color: white;
  }

  /* Mobile Layout */
  .footer__mobile {
    display: none;
    margin-bottom: 2rem;
  }

  .footer__mobile-social {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  /* Divider */
  .footer__divider {
    border-top: 1px solid #1f2937;
    /* padding-top: 2rem; */
    /* margin-bottom: 2rem; */
    margin: 1rem 0;
  }

  /* Bottom Section */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
    color: #9ca3af;
    padding: 2rem 0;
  }

  .footer__link {
    color: #4ade80;
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer__link:hover {
    color: #86efac;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer__desktop {
      display: none;
    }

    .footer__mobile {
      display: block;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }

    .footer__container {
      padding-top: 2rem;
    }
  }
</style>
